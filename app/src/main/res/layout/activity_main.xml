<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <FrameLayout
        android:id="@+id/frameLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.google.android.material.bottomappbar.BottomAppBar
        android:id="@+id/bottomMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:backgroundTint="@android:color/black"
        app:fabAlignmentMode="center"
        app:fabAnimationMode="slide"
        app:fabCradleMargin="12dp"
        app:fabCradleRoundedCornerRadius="32dp"
        app:fabCradleVerticalOffset="30dp"
        app:hideOnScroll="false"/>

    <androidx.cardview.widget.CardView
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:layout_gravity="bottom|center"
        android:layout_marginBottom="35dp"
        app:cardCornerRadius="29dp"
        app:cardElevation="16dp"
        app:cardBackgroundColor="@color/white"
        app:layout_anchor="@id/bottomMenu"
        app:layout_anchorGravity="center">
        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fab"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:src="@drawable/play"
            app:backgroundTint="@android:color/black"
            app:tint="@color/white"
            app:shapeAppearanceOverlay="@style/FabCircular"/>
    </androidx.cardview.widget.CardView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@android:color/black"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/menu_bajo" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/bottom_sheet"
        android:background="@android:color/black"
        android:layout_gravity="bottom"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="0dp"
        app:behavior_hideable="true"
        app:behavior_fitToContents="false"
        app:behavior_halfExpandedRatio="0.85">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/expanded_player"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingTop="50dp"
                android:padding="20dp"
                android:visibility="gone"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="30dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/info"
                        android:onClick="collapseBottomSheet"
                        app:tint="@android:color/white" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Canción actual"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:textStyle="bold"/>

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/info"
                        app:tint="@android:color/white" />
                </LinearLayout>

                <ImageView
                    android:layout_width="280dp"
                    android:layout_height="280dp"
                    android:layout_gravity="center_horizontal"
                    android:src="@drawable/senosllevaelaire"
                    android:scaleType="centerCrop"
                    android:layout_marginBottom="40dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="El hombre pájaro"
                        android:textColor="@android:color/white"
                        android:textSize="24sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Robe"
                        android:textColor="@android:color/darker_gray"
                        android:textSize="16sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="5dp">

                    <SeekBar
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:progress="30"
                        android:max="100"
                        android:progressTint="@android:color/white"
                        android:thumbTint="@android:color/white"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="1:30"
                            android:textColor="@android:color/darker_gray"
                            android:textSize="12sp"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="4:20"
                            android:textColor="@android:color/darker_gray"
                            android:textSize="12sp"
                            android:gravity="end"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginTop="10dp">

                    <ImageButton
                        android:id="@+id/btnCorazonGrande"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:background="@android:color/transparent"
                        android:src="@drawable/corazon"
                        android:scaleType="fitCenter"
                        android:padding="18dp"
                        android:layout_marginBottom="20dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginTop="-50dp"
                        android:layout_marginStart="-5dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:layout_marginEnd="25dp">

                            <ImageButton
                                android:id="@+id/btnNoMeInteresa"
                                android:layout_width="70dp"
                                android:layout_height="70dp"
                                android:background="@android:color/transparent"
                                android:src="@drawable/brokenheart"
                                android:scaleType="fitCenter"
                                android:padding="16dp"
                                android:layout_marginEnd="2dp"/>

                            <ImageButton
                                android:id="@+id/btnPreviousGrande"
                                android:layout_width="70dp"
                                android:layout_height="70dp"
                                android:background="@android:color/transparent"
                                android:src="@drawable/atras"
                                android:scaleType="fitCenter"
                                android:padding="16dp"
                                android:layout_marginStart="2dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center"
                            android:layout_marginStart="25dp">

                            <ImageButton
                                android:id="@+id/btnNextGrande"
                                android:layout_width="70dp"
                                android:layout_height="70dp"
                                android:background="@android:color/transparent"
                                android:src="@drawable/adelante"
                                android:scaleType="fitCenter"
                                android:padding="16dp"
                                android:layout_marginEnd="2dp"/>

                            <ImageButton
                                android:id="@+id/btnAnadirLista"
                                android:layout_width="70dp"
                                android:layout_height="70dp"
                                android:background="@android:color/transparent"
                                android:src="@drawable/libraryadd"
                                android:scaleType="fitCenter"
                                android:padding="16dp"
                                android:layout_marginStart="2dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/mini_player"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="@android:color/black">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/senosllevaelaire"
                    android:scaleType="centerCrop"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingHorizontal="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="El hombre pájaro"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Robe"
                        android:textColor="@android:color/darker_gray"
                        android:textSize="12sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/botonmegusta"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@android:color/transparent"
                        android:src="@drawable/corazon"
                        android:scaleType="fitCenter"
                        android:padding="4dp"
                        android:layout_marginHorizontal="8dp"/>

                    <ImageButton
                        android:id="@+id/botonnext"
                        android:layout_width="43dp"
                        android:layout_height="43dp"
                        android:background="@android:color/transparent"
                        android:src="@drawable/next"
                        android:scaleType="fitCenter"
                        android:padding="4dp"
                        android:layout_marginHorizontal="8dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>